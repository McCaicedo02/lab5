<%- include("../../partials/header") %>

<section class="archive-stage">
  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-lg-10 col-xl-9">
        <div class="hero-card shadow-lg">
          <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
            <div>
              <p class="eyebrow mb-2">Admin Panel</p>
              <h1 class="display-6 app-title mb-0">Add Author</h1>
            </div>
            <a href="/authors" class="btn btn-outline-secondary">Back to Authors</a>
          </div>

          <form action="/author/new" method="post" class="search-card">
            <div class="row g-3">
              <div class="col-md-6">
                <label for="firstName" class="form-label">First Name</label>
                <input type="text" class="form-control form-control-lg" id="firstName" name="firstName" required>
              </div>

              <div class="col-md-6">
                <label for="lastName" class="form-label">Last Name</label>
                <input type="text" class="form-control form-control-lg" id="lastName" name="lastName" required>
              </div>

              <div class="col-md-6">
                <label for="dob" class="form-label">Date of Birth</label>
                <input type="date" class="form-control form-control-lg" id="dob" name="dob">
              </div>

              <div class="col-md-6">
                <label for="dod" class="form-label">Date of Death</label>
                <input type="date" class="form-control form-control-lg" id="dod" name="dod">
              </div>

              <div class="col-md-6">
                <label for="sex" class="form-label">Sex</label>
                <input type="text" class="form-control form-control-lg" id="sex" name="sex">
              </div>

              <div class="col-md-6">
                <label for="profession" class="form-label">Profession</label>
                <input type="text" class="form-control form-control-lg" id="profession" name="profession">
              </div>

              <div class="col-md-6">
                <label for="country" class="form-label">Country</label>
                <input type="text" class="form-control form-control-lg" id="country" name="country">
              </div>

              <div class="col-md-6">
                <label for="portrait" class="form-label">Portrait URL</label>
                <input type="text" class="form-control form-control-lg" id="portrait" name="portrait">
              </div>

              <div class="col-12">
                <label for="biography" class="form-label">Biography</label>
                <textarea class="form-control form-control-lg" id="biography" name="biography" rows="5"></textarea>
              </div>
            </div>

            <button type="submit" class="btn btn-primary w-100 mt-4">Save Author</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("../../partials/footer") %>
