<%- include("../../partials/header") %>

<section class="archive-stage">
  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-lg-11 col-xl-10">
        <div class="hero-card shadow-lg">
          <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
            <div>
              <p class="eyebrow mb-2">Admin Panel</p>
              <h1 class="display-6 app-title mb-0">Authors</h1>
            </div>
            <a href="/author/new" class="btn btn-primary">Add Author</a>
          </div>

          <% if (!authors.length) { %>
            <div class="empty-state">
              <h2 class="h4 mb-2">No authors found</h2>
              <p class="mb-0">Create an author record to get started.</p>
            </div>
          <% } else { %>
            <div class="results-grid">
              <% authors.forEach(author => { %>
                <article class="quote-card">
                  <h2 class="h5 mb-2"><%= author.firstName %> <%= author.lastName %></h2>
                  <p class="mb-2"><strong>Profession:</strong> <%= author.profession || 'N/A' %></p>
                  <p class="mb-2"><strong>Country:</strong> <%= author.country || 'N/A' %></p>
                  <p class="mb-2"><strong>Born:</strong> <%= author.dobDisplay || 'N/A' %></p>
                  <p class="mb-3"><strong>Died:</strong> <%= author.dodDisplay || 'N/A' %></p>
                  <div class="d-flex gap-2">
                    <a href="/author/edit?authorId=<%= author.authorId %>" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a href="/author/delete?authorId=<%= author.authorId %>" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this author and any related quotes?')">Delete</a>
                  </div>
                </article>
              <% }) %>
            </div>
          <% } %>

          <div class="text-center mt-4">
            <a href="/admin" class="btn btn-link utility-link">Back to Admin Home</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("../../partials/footer") %>
