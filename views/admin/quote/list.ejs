<%- include("../../partials/header") %>

<section class="archive-stage">
  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-lg-11 col-xl-10">
        <div class="hero-card shadow-lg">
          <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
            <div>
              <p class="eyebrow mb-2">Admin Panel</p>
              <h1 class="display-6 app-title mb-0">Quotes</h1>
            </div>
            <a href="/quote/new" class="btn btn-primary">Add Quote</a>
          </div>

          <% if (!quotes.length) { %>
            <div class="empty-state">
              <h2 class="h4 mb-2">No quotes found</h2>
              <p class="mb-0">Create a quote to get started.</p>
            </div>
          <% } else { %>
            <div class="results-grid">
              <% quotes.forEach(item => { %>
                <article class="quote-card">
                  <blockquote class="quote-text mb-3">"<%= item.quote %>"</blockquote>
                  <p class="mb-2"><strong>Author:</strong> <%= item.authorName %></p>
                  <p class="mb-2"><strong>Category:</strong> <%= item.category || 'Uncategorized' %></p>
                  <p class="mb-3"><strong>Likes:</strong> <%= item.likes ?? 0 %></p>
                  <div class="d-flex gap-2">
                    <a href="/quote/edit?quoteId=<%= item.quoteId %>" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a href="/quote/delete?quoteId=<%= item.quoteId %>" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this quote?')">Delete</a>
                  </div>
                </article>
              <% }) %>
            </div>
          <% } %>

          <div class="text-center mt-4">
            <a href="/admin" class="btn btn-link utility-link">Back to Admin Home</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("../../partials/footer") %>
